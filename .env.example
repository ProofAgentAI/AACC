# Public site URL (set to https://aacc-usa.org once the domain is assigned;
# on Netlify/Vercel previews this can be the deployment URL)
NEXT_PUBLIC_SITE_URL=

# Supabase project (Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only, for back-office user management. Never expose with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only SMTP for sending email as contact@aacc-usa.org
# (Namecheap Private Email). Never expose with NEXT_PUBLIC_.
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=contact@aacc-usa.org
SMTP_PASS=
